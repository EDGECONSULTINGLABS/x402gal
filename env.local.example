# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is gitignored.

# ── XRPL testnet ──────────────────────────────────────────────────────────────
# WebSocket endpoint. Use testnet for dev, mainnet (wss://s1.ripple.com) for prod.
XRPL_ENDPOINT=wss://s.altnet.rippletest.net:51233

# Treasury wallet — the account that signs swap + retire transactions.
# Generate one at https://xrpl.org/resources/dev-tools/xrp-faucets then fund it
# on testnet via the faucet. Copy the "secret" / "seed" value here.
XRPL_TREASURY_SEED=sEdT...yourSeedHere

# HydroCoin issuer — the XRPL account address that issues the HYDRO token.
# On testnet this can be the same account as the treasury for simplicity.
# On mainnet use a dedicated cold-wallet issuer.
HYDROCOIN_ISSUER=rYour...IssuerAddressHere

# HydroCoin currency code — exactly 3 ASCII chars or 40-char hex.
# "HYD" works for testnet. Change to the agreed code before mainnet.
HYDROCOIN_CURRENCY=HYD

# Black-hole retirement address on XRPL.
# rrrrrrrrrrrrrrrrrrrrrhoLvTp is the canonical XRPL black hole (no key).
XRPL_BLACKHOLE=rrrrrrrrrrrrrrrrrrrrrhoLvTp

# ── Multi-chain RPC endpoints (optional — ledger fallback if absent) ───────────
# When set, verifyPayment() performs real on-chain USDC balance + nonce checks
# before accepting a payment. Safe to omit for local dev / demo.

# Base (Coinbase L2) — get a free key at https://portal.cdp.coinbase.com
RPC_BASE=https://mainnet.base.org

# Ethereum mainnet — public endpoint or Infura/Alchemy key
RPC_ETHEREUM=https://eth.llamarpc.com

# Polygon PoS
RPC_POLYGON=https://polygon-rpc.com

# Avalanche C-chain — used by Apex-av1 agent
# Set AVALANCHE_NETWORK=fuji to test against Fuji testnet agents (e.g. Fyodor/Saul demo)
# Set AVALANCHE_NETWORK=mainnet (default) for production with Circle native USDC
AVALANCHE_NETWORK=fuji
RPC_AVALANCHE=https://api.avax-test.network/ext/bc/C/rpc
# For mainnet, use:
# AVALANCHE_NETWORK=mainnet
# RPC_AVALANCHE=https://api.avax.network/ext/bc/C/rpc

# Solana mainnet-beta — stub only, full verification pending @solana/web3.js
RPC_SOLANA=https://api.mainnet-beta.solana.com

# ── EVM Treasury (pulls USDC from agent via ERC-3009) ─────────────────────────
# Generate a fresh wallet: node -e "const {privateKeyToAccount,generatePrivateKey}=require('viem/accounts');const pk=generatePrivateKey();console.log(pk,privateKeyToAccount(pk).address)"
# Fund with AVAX for gas: https://core.app/tools/testnet-faucet/?subnet=c&token=c
EVM_TREASURY_PRIVATE_KEY=0x...yourPrivateKeyHere
EVM_TREASURY_ADDRESS=0x...yourTreasuryAddressHere

# ── WalletConnect ──────────────────────────────────────────────────────────────
# Get a project ID at https://cloud.reown.com (free tier is fine)
NEXT_PUBLIC_REOWN_PROJECT_ID=demo_placeholder_replace_me
