# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local. It is gitignored.
#
# Variable names below match exactly what the code reads via process.env.

# ── XRPL ──────────────────────────────────────────────────────────────────────
# WebSocket endpoint. Use testnet for dev, mainnet (wss://s1.ripple.com) for prod.
XRPL_ENDPOINT=wss://s.altnet.rippletest.net:51233

# Treasury wallet. Signs swap + retire transactions.
# Generate at https://xrpl.org/resources/dev-tools/xrp-faucets then fund on testnet.
# Copy the "secret" / "seed" value here, and its classic address below.
XRPL_TREASURY_SEED=sEdT...yourSeedHere
XRPL_TREASURY_ADDRESS=rYour...TreasuryAddressHere

# HydroCoin issuer. The XRPL account that issues the HYDRO token.
# On testnet this can be the same account as the treasury for simplicity.
# On mainnet use a dedicated cold-wallet issuer.
XRPL_ISSUER_SEED=sEd...issuerSeedHere
HYDROCOIN_ISSUER_ADDRESS=rYour...IssuerAddressHere

# HydroCoin currency code. Exactly 3 ASCII chars or 40-char hex. "HYD" works for testnet.
HYDROCOIN_CURRENCY=HYD

# ── Multi-chain RPC endpoints (optional, ledger fallback if absent) ────────────
# When set, verifyPayment() performs real on-chain USDC balance + nonce checks.
RPC_BASE=https://mainnet.base.org
RPC_ETHEREUM=https://eth.llamarpc.com
RPC_POLYGON=https://polygon-rpc.com

# Avalanche C-chain. Set AVALANCHE_NETWORK=fuji for testnet agents, mainnet for prod.
AVALANCHE_NETWORK=fuji
RPC_AVALANCHE=https://api.avax-test.network/ext/bc/C/rpc

# Solana mainnet-beta. Stub only, full verification pending.
RPC_SOLANA=https://api.mainnet-beta.solana.com

# ── EVM Treasury (pulls USDC from agent via ERC-3009) ─────────────────────────
# Generate a fresh wallet:
#   node -e "const {privateKeyToAccount,generatePrivateKey}=require('viem/accounts');const pk=generatePrivateKey();console.log(pk,privateKeyToAccount(pk).address)"
# Fund with AVAX for gas: https://core.app/tools/testnet-faucet/?subnet=c&token=c
EVM_TREASURY_PRIVATE_KEY=0x...yourPrivateKeyHere
EVM_TREASURY_ADDRESS=0x...yourTreasuryAddressHere

# ── x402 facilitator ──────────────────────────────────────────────────────────
# Public client var. Bundled into the browser, so do NOT put a secret here.
NEXT_PUBLIC_FACILITATOR_URL=https://x402gal.xyz/api/x402/facilitate

# ── WalletConnect / Reown ─────────────────────────────────────────────────────
# Public client var. Get a project ID at https://cloud.reown.com (free tier is fine).
NEXT_PUBLIC_REOWN_PROJECT_ID=demo_placeholder_replace_me

# ── Upstash Redis (lead capture, agent numbers, funnel counters) ──────────────
# Required by /api/capture, /api/leads, /api/counter, /api/mint, /api/d365-sync.
# Redis.fromEnv() reads these two automatically. Get them at https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# ── INFILTRATE lead endpoints ─────────────────────────────────────────────────
# REQUIRED in any deployment. The /api/leads and /api/d365-sync routes now fail
# closed: if this is unset, all requests are rejected (no attendee data leaks).
LEADS_SECRET=generate_a_long_random_string

# Event namespace used as the Redis key prefix.
EVENT_ID=ethconf-nyc-2026

# Starting offset for the displayed live agent count.
AGENT_NUMBER_SEED=141

# ── Badge emails (Resend) ─────────────────────────────────────────────────────
# Get a key at https://resend.com. EMAIL_FROM must be a verified sender domain.
RESEND_API_KEY=re_...yourResendKeyHere
EMAIL_FROM=INFILTRATE <badges@x402gal.com>

# Base URL for NFT badge metadata.
BADGE_META_BASE=https://www.hydrocoin.com/infiltrate/badge

# ── Dynamics 365 sync (optional) ──────────────────────────────────────────────
# Only needed if /api/d365-sync pushes leads into Dynamics.
D365_TENANT_ID=your_tenant_id
D365_CLIENT_ID=your_app_registration_client_id
D365_CLIENT_SECRET=your_app_registration_client_secret
D365_ORG_URL=https://yourorg.crm.dynamics.com

# ── Scripts (optional) ────────────────────────────────────────────────────────
# Base URL used by scripts/demo-agent.ts. Defaults to http://localhost:3000.
BASE=http://localhost:3000
