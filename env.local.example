# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is gitignored.

# ── XRPL testnet ──────────────────────────────────────────────────────────────
# WebSocket endpoint. Use testnet for dev, mainnet (wss://s1.ripple.com) for prod.
XRPL_ENDPOINT=wss://s.altnet.rippletest.net:51233

# Treasury wallet — the account that signs swap + retire transactions.
# Generate one at https://xrpl.org/resources/dev-tools/xrp-faucets then fund it
# on testnet via the faucet. Copy the "secret" / "seed" value here.
XRPL_TREASURY_SEED=sEdT...yourSeedHere

# HydroCoin issuer — the XRPL account address that issues the HYDRO token.
# On testnet this can be the same account as the treasury for simplicity.
# On mainnet use a dedicated cold-wallet issuer.
HYDROCOIN_ISSUER=rYour...IssuerAddressHere

# HydroCoin currency code — exactly 3 ASCII chars or 40-char hex.
# "HYD" works for testnet. Change to the agreed code before mainnet.
HYDROCOIN_CURRENCY=HYD

# Black-hole retirement address on XRPL.
# rrrrrrrrrrrrrrrrrrrrrhoLvTp is the canonical XRPL black hole (no key).
XRPL_BLACKHOLE=rrrrrrrrrrrrrrrrrrrrrhoLvTp
