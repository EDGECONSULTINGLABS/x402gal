<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="64" height="64">
  <rect width="64" height="64" rx="12" fill="#1e40af"/>
  <!-- Head -->
  <rect x="18" y="14" width="28" height="24" rx="6" fill="none" stroke="#ffffff" stroke-width="3"/>
  <!-- Eyes -->
  <circle cx="26" cy="26" r="3" fill="#ffffff"/>
  <circle cx="38" cy="26" r="3" fill="#ffffff"/>
  <!-- Mouth -->
  <rect x="24" y="32" width="16" height="3" rx="1.5" fill="#ffffff"/>
  <!-- Antenna -->
  <line x1="32" y1="14" x2="32" y2="8" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round"/>
  <circle cx="32" cy="6" r="3" fill="#ffffff"/>
  <!-- Body -->
  <rect x="22" y="40" width="20" height="14" rx="4" fill="none" stroke="#ffffff" stroke-width="3"/>
  <!-- Arms -->
  <line x1="22" y1="44" x2="14" y2="48" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round"/>
  <line x1="42" y1="44" x2="50" y2="48" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round"/>
  <!-- Legs -->
  <line x1="28" y1="54" x2="28" y2="60" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round"/>
  <line x1="36" y1="54" x2="36" y2="60" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round"/>
</svg>
